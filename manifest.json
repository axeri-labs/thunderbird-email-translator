{
  "manifest_version": 2,
  "name": "E-mail Fordító",
  "version": "1.7.0",
  "description": "Translates the open email to Hungarian — shows translation in a split view inside Thunderbird.",
  "author": "kapcsolat@termuves.hu",
  "applications": {
    "gecko": {
      "id": "email-fordito@termuves.hu",
      "strict_min_version": "91.0"
    }
  },
  "icons": {
    "48": "icons/translate.svg",
    "96": "icons/translate.svg"
  },
  "message_display_action": {
    "default_title": "Translate to Hungarian",
    "default_icon": {
      "48": "icons/translate.svg"
    },
    "default_popup": "panel/panel.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "experiment_apis": {
    "emailTranslator": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiment/implementation.js",
        "paths": [["emailTranslator"]]
      }
    }
  },
  "permissions": [
    "messagesRead",
    "tabs",
    "storage",
    "webNavigation",
    "*://translate.googleapis.com/*"
  ]
}
