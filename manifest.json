{
  "manifest_version": 2,
  "name": "Email Translator",
  "version": "1.0.0",
  "description": "Translates the open email to the selected language — shows translation in a split view inside Thunderbird.",
  "author": "info@axeri.hu",
  "applications": {
    "gecko": {
      "id": "email-fordito@axeri.hu",
      "strict_min_version": "102.0"
    }
  },
  "icons": {
    "48": "icons/translate-48.png",
    "96": "icons/translate-96.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "message_display_action": {
    "default_title": "Translate email",
    "default_icon": {
      "48": "icons/translate.svg"
    }
  },
  "background": {
    "page": "background.html"
  },
  "permissions": [
    "messagesRead",
    "messagesModify",
    "tabs",
    "storage",
    "*://translate.googleapis.com/*",
    "*://api.mymemory.translated.net/*",
    "*://api-free.deepl.com/*"
  ]
}
