{
  "manifest_version": 2,
  "name": "E-mail Fordító",
  "version": "1.8.0",
  "description": "Translates the open email to the selected language — shows translation in a split view inside Thunderbird.",
  "author": "info@axeri.hu",
  "applications": {
    "gecko": {
      "id": "email-fordito@axeri.hu",
      "strict_min_version": "91.0"
    }
  },
  "icons": {
    "48": "icons/translate.svg",
    "96": "icons/translate.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "message_display_action": {
    "default_title": "E-mail fordítása",
    "default_icon": {
      "48": "icons/translate.svg"
    }
  },
  "background": {
    "page": "background.html"
  },
  "experiment_apis": {
    "emailTranslator": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiment/implementation.js",
        "paths": [["emailTranslator"]]
      }
    }
  },
  "permissions": [
    "messagesRead",
    "tabs",
    "storage",
    "webNavigation",
    "*://translate.googleapis.com/*"
  ]
}
